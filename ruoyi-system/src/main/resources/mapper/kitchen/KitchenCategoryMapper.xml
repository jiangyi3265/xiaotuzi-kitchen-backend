<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.kitchen.mapper.KitchenCategoryMapper">

    <resultMap type="KitchenCategory" id="KitchenCategoryResult">
        <id     property="id"         column="id"          />
        <result property="parentId"   column="parent_id"   />
        <result property="ancestors"  column="ancestors"   />
        <result property="catName"    column="cat_name"    />
        <result property="image"      column="image"       />
        <result property="catLevel"   column="cat_level"   />
        <result property="orderNum"   column="order_num"   />
        <result property="status"     column="status"      />
        <result property="createBy"   column="create_by"   />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by"   />
        <result property="updateTime" column="update_time" />
        <result property="remark"     column="remark"      />
    </resultMap>

    <sql id="selectKitchenCategoryVo">
        select id, parent_id, ancestors, cat_name, image, cat_level, order_num, status,
               create_by, create_time, update_by, update_time, remark
        from kitchen_category
    </sql>

    <select id="selectKitchenCategoryList" parameterType="KitchenCategory" resultMap="KitchenCategoryResult">
        <include refid="selectKitchenCategoryVo"/>
        <where>
            del_flag = '0'
            <if test="parentId != null">                       AND parent_id = #{parentId}</if>
            <if test="catName != null and catName != ''">      AND cat_name like concat('%', #{catName}, '%')</if>
            <if test="catLevel != null">                       AND cat_level = #{catLevel}</if>
            <if test="status != null and status != ''">        AND status = #{status}</if>
        </where>
        order by parent_id, order_num
    </select>

    <select id="selectKitchenCategoryById" parameterType="Long" resultMap="KitchenCategoryResult">
        <include refid="selectKitchenCategoryVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectChildrenCountByParentId" parameterType="Long" resultType="int">
        select count(1) from kitchen_category where parent_id = #{parentId} and del_flag = '0'
    </select>

    <insert id="insertKitchenCategory" parameterType="KitchenCategory" useGeneratedKeys="true" keyProperty="id">
        insert into kitchen_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="ancestors != null">ancestors,</if>
            <if test="catName != null and catName != ''">cat_name,</if>
            <if test="image != null">image,</if>
            <if test="catLevel != null">cat_level,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="ancestors != null">#{ancestors},</if>
            <if test="catName != null and catName != ''">#{catName},</if>
            <if test="image != null">#{image},</if>
            <if test="catLevel != null">#{catLevel},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateKitchenCategory" parameterType="KitchenCategory">
        update kitchen_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="ancestors != null">ancestors = #{ancestors},</if>
            <if test="catName != null and catName != ''">cat_name = #{catName},</if>
            <if test="image != null">image = #{image},</if>
            <if test="catLevel != null">cat_level = #{catLevel},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <update id="deleteKitchenCategoryById" parameterType="Long">
        update kitchen_category set del_flag = '2' where id = #{id}
    </update>

    <update id="deleteKitchenCategoryByIds" parameterType="String">
        update kitchen_category set del_flag = '2' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
