<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.kitchen.mapper.KitchenWxUserMapper">

    <resultMap type="KitchenWxUser" id="KitchenWxUserResult">
        <id     property="id"         column="id"          />
        <result property="openid"     column="openid"      />
        <result property="unionId"    column="union_id"    />
        <result property="nickname"   column="nickname"    />
        <result property="avatar"     column="avatar"      />
        <result property="userCode"   column="user_code"   />
        <result property="phone"      column="phone"       />
        <result property="gender"     column="gender"      />
        <result property="carrot"     column="carrot"      />
        <result property="status"     column="status"      />
        <result property="isOwner"    column="is_owner"    />
        <result property="createBy"   column="create_by"   />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by"   />
        <result property="updateTime" column="update_time" />
        <result property="remark"     column="remark"      />
    </resultMap>

    <sql id="selectKitchenWxUserVo">
        select id, openid, union_id, nickname, avatar, user_code, phone, gender, carrot, status, is_owner,
               create_by, create_time, update_by, update_time, remark
        from kitchen_wx_user
    </sql>

    <select id="selectKitchenWxUserList" parameterType="KitchenWxUser" resultMap="KitchenWxUserResult">
        <include refid="selectKitchenWxUserVo"/>
        <where>
            del_flag = '0'
            <if test="nickname != null and nickname != ''"> AND nickname like concat('%', #{nickname}, '%')</if>
            <if test="phone != null and phone != ''">       AND phone = #{phone}</if>
            <if test="openid != null and openid != ''">     AND openid = #{openid}</if>
            <if test="status != null and status != ''">     AND status = #{status}</if>
        </where>
        order by id desc
    </select>

    <select id="selectKitchenWxUserById" parameterType="Long" resultMap="KitchenWxUserResult">
        <include refid="selectKitchenWxUserVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectKitchenWxUserByOpenid" parameterType="String" resultMap="KitchenWxUserResult">
        <include refid="selectKitchenWxUserVo"/>
        where openid = #{openid} and del_flag = '0' limit 1
    </select>

    <insert id="insertKitchenWxUser" parameterType="KitchenWxUser" useGeneratedKeys="true" keyProperty="id">
        insert into kitchen_wx_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="openid != null and openid != ''">openid,</if>
            <if test="unionId != null">union_id,</if>
            <if test="nickname != null">nickname,</if>
            <if test="avatar != null">avatar,</if>
            <if test="userCode != null">user_code,</if>
            <if test="phone != null">phone,</if>
            <if test="gender != null">gender,</if>
            <if test="carrot != null">carrot,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="openid != null and openid != ''">#{openid},</if>
            <if test="unionId != null">#{unionId},</if>
            <if test="nickname != null">#{nickname},</if>
            <if test="avatar != null">#{avatar},</if>
            <if test="userCode != null">#{userCode},</if>
            <if test="phone != null">#{phone},</if>
            <if test="gender != null">#{gender},</if>
            <if test="carrot != null">#{carrot},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateKitchenWxUser" parameterType="KitchenWxUser">
        update kitchen_wx_user
        <trim prefix="SET" suffixOverrides=",">
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="carrot != null">carrot = #{carrot},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isOwner != null">is_owner = #{isOwner},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <update id="deductCarrot">
        update kitchen_wx_user set carrot = carrot - #{amount}
        where id = #{id} and carrot >= #{amount}
    </update>

    <update id="deleteKitchenWxUserById" parameterType="Long">
        update kitchen_wx_user set del_flag = '2' where id = #{id}
    </update>

    <update id="deleteKitchenWxUserByIds" parameterType="String">
        update kitchen_wx_user set del_flag = '2' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

</mapper>
