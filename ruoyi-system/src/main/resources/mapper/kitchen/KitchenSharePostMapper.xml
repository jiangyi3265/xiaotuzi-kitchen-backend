<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.kitchen.mapper.KitchenSharePostMapper">

    <resultMap type="KitchenSharePost" id="KitchenSharePostResult">
        <id     property="id"           column="id"            />
        <result property="wxUserId"     column="wx_user_id"    />
        <result property="userNickname" column="user_nickname" />
        <result property="userAvatar"   column="user_avatar"   />
        <result property="title"        column="title"         />
        <result property="content"      column="content"       />
        <result property="images"       column="images"        />
        <result property="tags"         column="tags"          />
        <result property="likeCount"    column="like_count"    />
        <result property="commentCount" column="comment_count" />
        <result property="auditStatus"  column="audit_status"  />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectKitchenSharePostVo">
        select p.id, p.wx_user_id, u.nickname as user_nickname, u.avatar as user_avatar,
               p.title, p.content, p.images, p.tags,
               (select count(1) from kitchen_post_like l where l.post_id = p.id) as like_count,
               (select count(1) from kitchen_comment c
                where c.post_id = p.id and c.audit_status = '1' and c.del_flag = '0') as comment_count,
               p.audit_status,
               p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from kitchen_share_post p
        left join kitchen_wx_user u on u.id = p.wx_user_id
    </sql>

    <select id="selectKitchenSharePostList" parameterType="KitchenSharePost" resultMap="KitchenSharePostResult">
        <include refid="selectKitchenSharePostVo"/>
        <where>
            p.del_flag = '0'
            <if test="title != null and title != ''">           AND p.title like concat('%', #{title}, '%')</if>
            <if test="wxUserId != null">                          AND p.wx_user_id = #{wxUserId}</if>
            <if test="auditStatus != null and auditStatus != ''"> AND p.audit_status = #{auditStatus}</if>
        </where>
        order by p.id desc
    </select>

    <select id="selectKitchenSharePostById" parameterType="Long" resultMap="KitchenSharePostResult">
        <include refid="selectKitchenSharePostVo"/>
        where p.id = #{id} and p.del_flag = '0'
    </select>

    <insert id="insertKitchenSharePost" parameterType="KitchenSharePost" useGeneratedKeys="true" keyProperty="id">
        insert into kitchen_share_post
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="wxUserId != null">wx_user_id,</if>
            <if test="title != null">title,</if>
            <if test="content != null">content,</if>
            <if test="images != null">images,</if>
            <if test="tags != null">tags,</if>
            <if test="auditStatus != null">audit_status,</if>
            <if test="remark != null">remark,</if>
            like_count, comment_count, create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="wxUserId != null">#{wxUserId},</if>
            <if test="title != null">#{title},</if>
            <if test="content != null">#{content},</if>
            <if test="images != null">#{images},</if>
            <if test="tags != null">#{tags},</if>
            <if test="auditStatus != null">#{auditStatus},</if>
            <if test="remark != null">#{remark},</if>
            0, 0, sysdate()
        </trim>
    </insert>

    <update id="updateKitchenSharePost" parameterType="KitchenSharePost">
        update kitchen_share_post
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="images != null">images = #{images},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="commentCount != null">comment_count = #{commentCount},</if>
            <if test="auditStatus != null">audit_status = #{auditStatus},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <update id="addLike" parameterType="Long">
        update kitchen_share_post set like_count = like_count + 1 where id = #{id}
    </update>

    <update id="decLike" parameterType="Long">
        update kitchen_share_post set like_count = case when like_count > 0 then like_count - 1 else 0 end where id = #{id}
    </update>

    <update id="deleteKitchenSharePostById" parameterType="Long">
        update kitchen_share_post set del_flag = '2' where id = #{id}
    </update>

    <update id="deleteKitchenSharePostByIds" parameterType="String">
        update kitchen_share_post set del_flag = '2' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </update>

</mapper>
